@page "{listingId:long}"
@model SwoopMarketplaceProjectFrontend.Pages.Reports.CreateModel

@{
    ViewData["Title"] = "Report listing";
}

<div style="max-width: 900px; margin: 24px auto; padding: 0 16px;">
    <h1 style="margin-bottom: 8px;">Report listing</h1>
    <p style="color: #6b7280; margin-bottom: 24px;">
        Report the exact listing below and describe the issue clearly.
    </p>

    @if (Model.Listing is null)
    {
        <div class="alert alert-warning">
            The requested listing could not be found.
        </div>
        <a asp-page="/Listings/Index" class="btn btn-primary">Back to listings</a>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body">
                <div class="text-muted mb-2">Listing #@Model.Listing.Id</div>
                <h2 class="h4 mb-2">@Model.Listing.Title</h2>
                <div class="mb-2">
                    <strong>Category:</strong> @(Model.Listing.CategoryName ?? "Unknown")
                </div>
                <div class="mb-2">
                    <strong>Price:</strong> @Model.Listing.Price.ToString("C")
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Listing.Location))
                {
                    <div class="mb-2">
                        <strong>Location:</strong> @Model.Listing.Location
                    </div>
                }
                <div class="text-muted">
                    @Model.Listing.Description
                </div>

                <div class="mt-3">
                    <a asp-page="/Listings/Details" asp-route-azon="@Model.Listing.Id">Open listing details</a>
                </div>
            </div>
        </div>

        <form method="post" class="card">
            <div class="card-body">
                <input type="hidden" asp-for="ListingId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Description" class="form-label">Report description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="6" placeholder="Describe why this listing should be reviewed..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-danger">Submit report</button>
                <a asp-page="/Listings/Details" asp-route-azon="@Model.Listing.Id" class="btn btn-outline-secondary ms-2">
                    Cancel
                </a>
            </div>
        </form>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
