@page
@model SwoopMarketplaceProjectFrontend.Pages.Messages.IndexModel
@using SwoopMarketplaceProjectFrontend.Services
@inject AuthSession AuthSession
@{
    ViewData["Title"] = "Üzenetek";
}

<div style="padding:8px 12px;max-width:900px;margin:0 auto;">
    <h2 style="margin:10px 0 18px;font-family:Segoe UI,Roboto,Arial,sans-serif;color:#222;">Üzenetek</h2>

    <div style="margin-bottom:20px;">
        <input id="convSearch"
               class="form-control"
               placeholder="Keresés név vagy üzenet alapján..."
               style="max-width:400px;border-radius:8px;" />
    </div>

    @if (Model.Conversations == null || !Model.Conversations.Any())
    {
        <div style="text-align:center;padding:60px 20px;background:#fff;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.08);">
            <div style="font-size:48px;margin-bottom:20px;opacity:0.6;">📭</div>
            <h3 style="font-size:20px;font-weight:600;color:#374151;margin-bottom:12px;">Még nincsenek üzeneteid</h3>
            <p style="color:#6b7280;margin-bottom:24px;">Kezdj el beszélgetni más felhasználókkal! Írj üzenetet egy hirdetés alatt.</p>
            <a asp-page="/Listings/Index"
               style="display:inline-block;padding:12px 24px;background:#6c5ce7;color:white;text-decoration:none;border-radius:8px;font-weight:600;">
                Hirdetések böngészése
            </a>
        </div>
    }
    else
    {
        <div id="conversationsList" style="background:#fff;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.08);overflow:hidden;">
            @foreach (var c in Model.Conversations)
            {
                var isUnread = c.UnreadCount > 0;
                var unreadBg = isUnread ? "background:#fff7ed;border-left:4px solid #ff6b35;" : "";
                var listingTitle = !string.IsNullOrWhiteSpace(c.ListingTitle) ? c.ListingTitle : null;
                var timeAgo = DateTime.Now - c.LastAt.ToLocalTime();
                var timeText = timeAgo.TotalDays >= 1
                    ? c.LastAt.ToLocalTime().ToString("MM/dd")
                    : timeAgo.TotalHours >= 1
                        ? $"{(int)timeAgo.TotalHours}h"
                        : $"{(int)timeAgo.TotalMinutes}m";

                <div class="conv-row" style="display:flex;align-items:center;gap:0;border-bottom:1px solid #f1f3f4;@unreadBg">

                    @* ── Kattintható beszélgetés rész ── *@
                    <a asp-page="./Conversation"
                       asp-route-to="@c.OtherUserId"
                       asp-route-listing="@c.ListingId"
                       style="display:flex;align-items:center;gap:12px;padding:14px 16px;text-decoration:none;color:inherit;flex:1;min-width:0;transition:background .15s;"
                       onmouseover="this.style.background='#f8f9fa'"
                       onmouseout="this.style.background='transparent'">

                        <img src="@(string.IsNullOrWhiteSpace(c.OtherProfileImageUrl) ? "/images/avatar.png" : c.OtherProfileImageUrl)"
                             alt="@c.OtherUserName profilkép"
                             style="width:48px;height:48px;border-radius:50%;object-fit:cover;border:2px solid #e5e7eb;flex-shrink:0;" />

                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">
                                <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;min-width:0;">
                                    <span style="font-size:15px;font-weight:700;color:#1f2937;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@c.OtherUserName</span>
                                    @if (listingTitle != null)
                                    {
                                        <span style="background:#6c5ce7;color:white;padding:2px 7px;border-radius:10px;font-size:11px;font-weight:600;white-space:nowrap;">@listingTitle</span>
                                    }
                                </div>
                                <span style="font-size:12px;color:#9ca3af;white-space:nowrap;margin-left:8px;">@timeText</span>
                            </div>

                            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                                <span style="color:#6b7280;font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">
                                    @if (string.IsNullOrWhiteSpace(c.LastMessage))
                                    {
                                        <em>Új beszélgetés...</em>
                                    }
                                    else
                                    {
                                        @c.LastMessage
                                    }
                                </span>
                                @if (isUnread)
                                {
                                    <span style="background:#ff6b35;color:white;padding:3px 8px;border-radius:10px;font-size:11px;font-weight:700;white-space:nowrap;flex-shrink:0;">
                                        @c.UnreadCount új
                                    </span>
                                }
                            </div>
                        </div>
                    </a>

                    @* ── Törlés gomb a sor végén, a névsor mellett ── *@
                    <div style="padding:0 12px;flex-shrink:0;">
                        <form method="post" asp-page-handler="DeleteConversation"
                              onsubmit="return confirm('Biztosan törlöd ezt a beszélgetést? A másik félnél megmarad.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="otherUserId" value="@c.OtherUserId" />
                            <input type="hidden" name="listingId" value="@c.ListingId" />
                            <button type="submit"
                                    title="Beszélgetés törlése"
                                    style="background:none;border:1px solid #fecaca;color:#ef4444;border-radius:8px;padding:6px 10px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:4px;transition:background .15s;white-space:nowrap;"
                                    onmouseover="this.style.background='#fff1f2'"
                                    onmouseout="this.style.background='none'">
                                ❌
                            </button>
                        </form>
                    </div>

                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var search = document.getElementById('convSearch');
            if (!search) return;
            var list = document.getElementById('conversationsList');
            if (!list) return;

            search.addEventListener('input', function () {
                var query = search.value.trim().toLowerCase();
                var rows = Array.from(list.querySelectorAll('.conv-row'));

                rows.forEach(function (row) {
                    var text = (row.innerText || row.textContent || '').toLowerCase();
                    row.style.display = !query || text.includes(query) ? 'flex' : 'none';
                });

                var visible = rows.filter(r => r.style.display !== 'none').length;
                var existing = document.querySelector('.search-empty');

                if (query && visible === 0 && !existing) {
                    var d = document.createElement('div');
                    d.className = 'search-empty';
                    d.style.cssText = 'text-align:center;padding:40px;color:#6b7280;';
                    d.innerHTML = '<div style="font-size:32px;margin-bottom:12px;">🔍</div>' +
                        '<h3>Nincs találat</h3>' +
                        '<p>Nem találtunk beszélgetést: "<strong>' + query + '</strong>"</p>';
                    list.appendChild(d);
                } else if ((!query || visible > 0) && existing) {
                    existing.remove();
                }
            });
        })();
    </script>
}