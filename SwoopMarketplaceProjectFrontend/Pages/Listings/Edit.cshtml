@page "{azon:int}"
@model SwoopMarketplaceProjectFrontend.Pages.Listings.EditModel
@inject SwoopMarketplaceProjectFrontend.Services.AuthSession AuthSession;

<h1>Edit listing</h1>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

@if (Model.Input is null)
{
    <div class="alert alert-warning">Listing not found.</div>
}
else
{
    <form method="post" enctype="multipart/form-data" style="max-width:760px;">
        <input asp-for="Input.Id" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <label class="form-label">Title</label>
        <input asp-for="Input.Title" class="form-control mb-2" />
        <span asp-validation-for="Input.Title" class="text-danger"></span>

        <label class="form-label">Price</label>
        <input asp-for="Input.Price" type="number" step="0.01" class="form-control mb-2" />

        <label class="form-label">Category</label>
        <select asp-for="Input.CategoryId" class="form-control mb-2">
            <option value="">-- Select a category --</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Id" selected="@(Model.Input.CategoryId == c.Id ? "selected" : null)">@c.Name</option>
            }
        </select>
        <span asp-validation-for="Input.CategoryId" class="text-danger"></span>

        <label class="form-label">Condition</label>
        <select asp-for="Input.Condition" class="form-control mb-2">
            <option value="used" selected="@(Model.Input.Condition == "used" ? "selected" : null)">Used</option>
            <option value="new" selected="@(Model.Input.Condition == "new" ? "selected" : null)">New</option>
        </select>

        <label class="form-label">Location</label>
        <input asp-for="Input.Location" class="form-control mb-2" />

        <label class="form-label">Description</label>
        <textarea asp-for="Input.Description" rows="6" class="form-control mb-2"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>

        <label class="form-label">Existing images</label>
        <div class="mb-2">
            @if (Model.Input.ImageUrls?.Any() == true)
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var url in Model.Input.ImageUrls)
                    {
                        <div style="width:120px">
                            <img src="@url" alt="img" style="max-width:100%;border-radius:6px" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted">No images</div>
            }
        </div>

        <label class="form-label">Add new images (optional)</label>
        <input type="file" name="uploads" accept="image/*" multiple class="form-control mb-3" />

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="/Listings/Details" asp-route-azon="@Model.Input.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
