@page "{azon:int}"
@model SwoopMarketplaceProjectFrontend.Pages.Listings.EditModel
@inject SwoopMarketplaceProjectFrontend.Services.AuthSession AuthSession;

<h1>Edit listing</h1>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

@if (Model.Input is null)
{
    <div class="alert alert-warning">Listing not found.</div>
}
else
{
    @* Existing images (radio selector placed here but radios are outside main form).
       We will copy the selected radio value into the hidden input inside the main form on submit. *@
    <label class="form-label">Existing images</label>
    <div class="mb-3">
        @if (Model.ExistingImages != null && Model.ExistingImages.Any())
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var img in Model.ExistingImages)
                {
                    <div style="width:120px;position:relative">
                        <img src="@img.ImageUrl" alt="img" style="max-width:100%;border-radius:6px" />
                        <div style="position:absolute;left:6px;bottom:6px;">
                            <input type="radio" name="primarySelector" id="prim_@img.Id" value="@img.Id" @(img.IsPrimary == true ? "checked" : "") />
                            <label for="prim_@img.Id" class="small text-white" style="background:#00000055;padding:2px 6px;border-radius:6px;color:#fff;font-size:12px">Primary</label>
                        </div>
                        @if (img.Id > 0)
                        {
                            <form method="post" asp-page-handler="DeleteImage" style="position:absolute;top:6px;right:6px;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@img.Id" />
                                <input type="hidden" name="listingId" value="@Model.Input.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this image?');">×</button>
                            </form>
                        }
                    </div>
                }
            </div>
        }
        else if (Model.Input.ImageUrls != null && Model.Input.ImageUrls.Any())
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var url in Model.Input.ImageUrls)
                {
                    <div style="width:120px;position:relative">
                        <img src="@url" alt="img" style="max-width:100%;border-radius:6px" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-muted">No images</div>
        }
    </div>

    <form method="post" enctype="multipart/form-data" style="max-width:760px;" id="editForm">
        <input asp-for="Input.Id" type="hidden" />
        @* hidden primary Image id copied by JS on submit *@
        <input type="hidden" name="primaryImageId" value="" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <label class="form-label">Title</label>
        <input asp-for="Input.Title" class="form-control mb-2" />
        <span asp-validation-for="Input.Title" class="text-danger"></span>

        <label class="form-label">Price</label>
        <input asp-for="Input.Price" type="number" step="0.01" class="form-control mb-2" />

        <label class="form-label">Category</label>
        <select asp-for="Input.CategoryId" class="form-control mb-2">
            <option value="">-- Select a category --</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Id" selected="@(Model.Input.CategoryId == c.Id ? "selected" : null)">@c.Name</option>
            }
        </select>
        <span asp-validation-for="Input.CategoryId" class="text-danger"></span>

        <label class="form-label">Condition</label>
        <select asp-for="Input.Condition" class="form-control mb-2">
            <option value="used" selected="@(Model.Input.Condition == "used" ? "selected" : null)">Used</option>
            <option value="new" selected="@(Model.Input.Condition == "new" ? "selected" : null)">New</option>
        </select>

        <label class="form-label">Location</label>
        <input asp-for="Input.Location" class="form-control mb-2" />

        <label class="form-label">Description</label>
        <textarea asp-for="Input.Description" rows="6" class="form-control mb-2"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>

        <label class="form-label">Add new images (optional)</label>
        <input type="file" name="uploads" accept="image/*" multiple class="form-control mb-3" />

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="/Listings/Details" asp-route-azon="@Model.Input.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // copy selected radio value into hidden input inside the main form before submit
        (function () {
            var form = document.getElementById('editForm');
            if (!form) return;
            form.addEventListener('submit', function () {
                var sel = document.querySelector('input[name="primarySelector"]:checked');
                if (sel) {
                    var hidden = form.querySelector('input[name="primaryImageId"]');
                    if (hidden) hidden.value = sel.value;
                }
            });
        })();
    </script>
}
