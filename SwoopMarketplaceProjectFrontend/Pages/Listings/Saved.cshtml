@page
@model SwoopMarketplaceProjectFrontend.Pages.Listings.SavedModel
@using System.Security.Cryptography
@using System.Text
@using SwoopMarketplaceProjectFrontend.Services
@inject AuthSession AuthSession
@{
    ViewData["Title"] = "Mentett Hírdetések";
}

@functions {
    private static string GravatarUrl(string? email, int size = 64)
    {
        if (string.IsNullOrWhiteSpace(email))
            return $"/images/avatar.png";
        using var md5 = MD5.Create();
        var hash = BitConverter.ToString(md5.ComputeHash(Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()))).Replace("-", "").ToLowerInvariant();
        return $"https://www.gravatar.com/avatar/{hash}?s={size}&d=identicon";
    }

    private static string Truncate(string? text, int len = 120)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;
        return text.Length <= len ? text : text.Substring(0, len).TrimEnd() + "…";
    }
}

<div style="padding:8px 12px;max-width:1200px;margin:0 auto;">
    <h1 style="margin:10px 0 18px;font-family:Segoe UI,Roboto,Arial,sans-serif;color:#222">Mentett</h1>

    @if (!AuthSession.IsSignedIn)
    {
        <div class="alert alert-info">Kérlek előbb jelentkezz be!</div>
    }
    else if (Model.ListingsWithOwners.Count == 0)
    {
        <div class="alert alert-secondary">Nincsen elmentett hírdetésed!</div>
    }

    <div id="listingsGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:18px;align-items:start;">
        @foreach (var item in Model.ListingsWithOwners)
        {
            var n = item.Listing;
            var imageUrl = (n.ImageUrls != null && n.ImageUrls.Count > 0) ? n.ImageUrls[0] : "/images/placeholder.png";
            var avatar = !string.IsNullOrWhiteSpace(item.OwnerProfileImageUrl) ? item.OwnerProfileImageUrl : GravatarUrl(item.OwnerEmail);
            var displayName = !string.IsNullOrWhiteSpace(item.OwnerUserName) ? item.OwnerUserName : (item.OwnerEmail?.Split('@').FirstOrDefault() ?? "Eladó");

            <div class="listing-card"
                 data-title="@n.Title.ToLowerInvariant()"
                 data-location="@((n.Location ?? "").ToLowerInvariant())"
                 data-owner="@displayName.ToLowerInvariant()"
                 style="background:#fff;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.08);overflow:hidden;display:flex;flex-direction:column;">

                <div style="height:180px;background:#f4f6fb center/cover no-repeat;border-bottom:1px solid rgba(0,0,0,0.04);background-image:url('@imageUrl');"></div>

                <div style="padding:12px;display:flex;flex-direction:column;gap:6px;flex:1;">
                    <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;">
                        <div style="flex:1;min-width:0;">
                            <a asp-page="./Details" asp-route-azon="@n.Id" style="text-decoration:none;color:inherit;">
                                <div style="font-weight:700;font-size:15px;line-height:1.25;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#1a1a2e;">
                                    @n.Title
                                </div>
                                <div style="height:1px;background:linear-gradient(90deg,#e0deff,transparent);margin:5px 0 5px;border-radius:1px;"></div>
                                <div style="display:inline-flex;align-items:center;background:linear-gradient(90deg,#eef2ff,#f0effe);color:#4c51bf;font-weight:800;font-size:13px;padding:3px 10px;border-radius:12px;">
                                    @n.Price.ToHuf()
                                </div>
                            </a>
                            <div style="font-size:12px;color:#9ca3af;margin-top:4px;">@((n.Location ?? "")) • @n.CreatedAt.ToString("yyyy-MM-dd")</div>
                        </div>

                        <div style="flex-shrink:0;">
                            <form method="post" asp-page-handler="ToggleBookmark" style="margin:0;">
                                <input type="hidden" name="azon" value="@n.Id" />
                                <button type="submit" title="Toggle bookmark" style="background:none;border:none;padding:6px;cursor:pointer;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <path d="M6 2a1 1 0 00-1 1v18l7-4 7 4V3a1 1 0 00-1-1H6z"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:auto;padding-top:6px;border-top:1px solid #f3f4f6;">
                        <div style="display:flex;align-items:center;gap:8px;">
                            <div style="width:36px;height:36px;border-radius:999px;overflow:hidden;border:2px solid #f0effe;box-shadow:0 2px 8px rgba(108,92,231,0.10);flex-shrink:0;">
                                <img src="@avatar" alt="Eladó" style="width:100%;height:100%;object-fit:cover;display:block;" />
                            </div>
                            <div>
                                <div style="font-weight:600;font-size:13px;color:#1a1a2e;max-width:110px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@displayName</div>
                                <div style="font-size:11px;color:#9ca3af;">@ConditionMapper.FriendlyName(n.Condition)</div>
                            </div>
                        </div>

                        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
                            <a asp-page="./Details" asp-route-azon="@n.Id" style="background:#eef2ff;color:#4c51bf;padding:6px 10px;border-radius:8px;text-decoration:none;font-weight:700;font-size:13px;">Megtekintés</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
