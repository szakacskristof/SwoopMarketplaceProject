@page "{azon:int}"
@model SwoopMarketplaceProjectFrontend.Pages.Listings.DetailsModel
@using System.Security.Cryptography
@using System.Text
@using SwoopMarketplaceProjectFrontend.Services
@{
    ViewData["Title"] = "Hírdetés Adatai";
}

@functions {
    private static string GravatarUrl(string? email, int size = 128)
    {
        if (string.IsNullOrWhiteSpace(email))
            return "/images/avatar.png";
        using var md5 = MD5.Create();
        var hash = BitConverter.ToString(md5.ComputeHash(Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()))).Replace("-", "").ToLowerInvariant();
        return $"https://www.gravatar.com/avatar/{hash}?s={size}&d=identicon";
    }
}

<style>
    /* ---- Modal style (kept) ---- */
    #listingModal .modal-dialog {
        max-width: 90vw;
    }

    #listingModal .modal-content {
        background: rgba(0,0,0,.92);
        border: none;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
    }

    #listingModal .modal-close-btn {
        position: absolute;
        right: 14px;
        top: 14px;
        z-index: 1201;
        background: rgba(255,255,255,.15);
        backdrop-filter: blur(6px);
        color: #fff;
        border: 1px solid rgba(255,255,255,.2);
        border-radius: 50%;
        width: 38px;
        height: 38px;
        font-size: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    #listingModal .carousel-control-prev-icon,
    #listingModal .carousel-control-next-icon {
        filter: invert(1);
    }

    /* ---- Disable slide animation ONLY inside the modal carousel ---- */
    #listingModal #listingModalCarousel .carousel-item {
        transition: none !important;
    }

        #listingModal #listingModalCarousel .carousel-item-next,
        #listingModal #listingModalCarousel .carousel-item-prev,
        #listingModal #listingModalCarousel .carousel-item.active {
            transition: none !important;
        }

    /* ---- Zoom (no animation) ---- */
    #listingModal .zoom-stage {
        height: 80vh;
        width: min(92vw, 1200px);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        cursor: zoom-in;
        transform-origin: center center;
        transition: none; /* no zoom animation */
    }

        #listingModal .zoom-stage.zoomed-in {
            transform: scale(1.5);
            cursor: zoom-out;
        }

    #listingModal img.modal-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        pointer-events: none; /* click handled on stage */
        user-select: none;
    }

    /* thumbs highlight (optional) */
    .gallery-thumb {
        width: 88px;
        height: 64px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid transparent;
        opacity: .85;
    }

        .gallery-thumb:hover {
            opacity: 1;
        }
</style>

@if (Model.Listing is null)
{
    <div style="max-width:1100px;margin:28px auto;padding:16px;background:#fff;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.06);">
        <h2 style="margin:0 0 8px;font-family:Segoe UI,Roboto,Arial,sans-serif;color:#222">Hirdetés nem található</h2>
        <p style="color:#6b7280">A kért hirdetés nem elérhető.</p>
        <a asp-page="./Index" style="display:inline-block;margin-top:10px;padding:8px 12px;background:#eef2ff;color:#4c51bf;border-radius:8px;text-decoration:none;font-weight:700">Vissza a listához</a>
    </div>
}
else
{
    var l = Model.Listing;
    var avatar = !string.IsNullOrWhiteSpace(Model.OwnerProfileImageUrl) ? Model.OwnerProfileImageUrl : GravatarUrl(Model.OwnerEmail);

    var imageList = l!.ImageUrls ?? new List<string>();
    var images = imageList.Any() ? imageList : new List<string> { "/images/placeholder.png" };

    <div style="display:flex;align-items:center;gap:8px;">
        <h1 style="margin:auto">@l.Title</h1>

        <form method="post" asp-page-handler="ToggleBookmark" style="margin:0;">
            <input type="hidden" name="azon" value="@l.Id" />
            <button type="submit" title="Könyvjelző ki/be" style="background:none;border:none;padding:6px;cursor:pointer;">
                @if (Model.IsBookmarked)
                {
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M6 2a1 1 0 00-1 1v18l7-4 7 4V3a1 1 0 00-1-1H6z" />
                    </svg>
                }
                else
                {
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M6 2a1 1 0 00-1 1v18l7-4 7 4V3a1 1 0 00-1-1H6z" />
                    </svg>
                }
            </button>
        </form>
    </div>

    <div style="max-width:1100px;margin:18px auto;display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start;">
        <!-- Left / gallery -->
        <section style="flex:1 1 640px;min-width:320px;">
            <div style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 10px 30px rgba(2,6,23,0.06);padding:0;">
                <div id="listingCarousel" class="carousel slide" data-bs-ride="false" data-bs-touch="true">
                    <div class="carousel-inner" style="height:460px;">
                        @for (int i = 0; i < images.Count; i++)
                        {
                            var url = images[i];
                            var active = i == 0 ? "active" : "";
                            <div class="carousel-item @active" style="height:100%;">
                                <img src="@url" class="d-block w-100" data-index="@i" style="height:100%;object-fit:cover;display:block;cursor:zoom-in" alt="Hirdetés képe @(i + 1)" />
                            </div>
                        }
                    </div>

                    @if (images.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev" aria-label="Előző">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next" aria-label="Következő">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        </button>
                    }
                </div>

                @if (images.Count > 1)
                {
                    <div class="d-flex gap-2 p-3" style="overflow-x:auto;background:#fff;border-top:1px solid #f1f5f9;">
                        @for (int i = 0; i < images.Count; i++)
                        {
                            var url = images[i];
                            <button type="button" class="btn p-0 border-0" data-bs-target="#listingCarousel" data-bs-slide-to="@i" style="flex:0 0 auto;" aria-label="Ugrás a(z) @(i + 1). képre">
                                <img src="@url" alt="Bélyegkép @(i + 1)" data-index="@i" class="gallery-thumb" style="cursor:zoom-in" />
                            </button>
                        }
                    </div>
                }

                <div class="modal fade" id="listingModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-xl modal-dialog-centered">
                        <div class="modal-content">
                            <button type="button" id="listingModalClose" title="Bezárás" class="modal-close-btn" aria-label="Bezárás">×</button>
                            <div class="modal-body p-0">
                                <div id="listingModalCarousel" class="carousel slide" data-bs-ride="false" data-bs-touch="true">
                                    <div class="carousel-inner" style="background:transparent;">
                                        @for (int i = 0; i < images.Count; i++)
                                        {
                                            var url = images[i];
                                            var active = i == 0 ? "active" : "";
                                            <div class="carousel-item @active" style="text-align:center;">
                                                <div class="zoom-stage">
                                                    <img src="@url" class="modal-image" alt="Hirdetés képe (nagyítva) @(i + 1)" />
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    @if (images.Count > 1)
                                    {
                                        <button class="carousel-control-prev" type="button" data-bs-target="#listingModalCarousel" data-bs-slide="prev" aria-label="Előző">
                                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                        </button>
                                        <button class="carousel-control-next" type="button" data-bs-target="#listingModalCarousel" data-bs-slide="next" aria-label="Következő">
                                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="padding:16px;">
                    <h1 style="margin:0 0 8px;font-size:22px;font-weight:800;color:#111">@l.Title</h1>
                    <div style="font-weight:700;font-size:15px;margin-bottom:6px;line-height:1.2;">@l.Price.ToHuf()
                    <div style="color:#6b7280;font-size:13px;margin-bottom:12px">@((l.Location ?? "Ismeretlen hely")) • @l.CreatedAt.ToString("yyyy-MM-dd")</div>

                    <div style="color:#333;line-height:1.5;font-size:15px;padding:12px;background:linear-gradient(180deg,#fff,#fbfdff);border-radius:8px;border:1px solid #f1f5f9;">
                        @l.Description
                    </div>

                    <div style="display:flex;gap:10px;margin-top:14px;flex-wrap:wrap">
                        <span style="padding:8px 10px;border-radius:10px;background:#f7f9fc;color:#374151;font-weight:700">Állapot: @ConditionMapper.FriendlyName(l.Condition)</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Right / seller & actions -->
        <aside style="width:360px;min-width:280px;display:flex;flex-direction:column;gap:12px">
            <div style="background:#fff;padding:16px;border-radius:12px;box-shadow:0 10px 30px rgba(2,6,23,0.06)">
                <div style="display:flex;gap:12px;align-items:center">
                    <div style="width:72px;height:72px;border-radius:999px;overflow:hidden;box-shadow:0 8px 20px rgba(12,18,44,0.06)">
                        <img src="@avatar" alt="Eladó" style="width:100%;height:100%;object-fit:cover;display:block" />
                    </div>
                    <div style="flex:1">
                        <div style="font-weight:800;font-size:16px;color:#111">@((Model.OwnerUserName ?? "Eladó"))</div>
                        <div style="font-size:13px;color:#6b7280">@Model.OwnerEmail</div>
                        @if (!string.IsNullOrWhiteSpace(Model.OwnerPhone))
                        {
                            <div style="font-size:13px;color:#6b7280;margin-top:4px">
                                Telefon:
                                <a href="tel:@Model.OwnerPhone" style="color:#111;font-weight:700;text-decoration:none;margin-left:6px">@Model.OwnerPhone</a>
                            </div>
                        }
                    </div>
                </div>

                <div style="margin-top:14px;display:flex;gap:10px;flex-wrap:wrap">
                    @if (!string.IsNullOrWhiteSpace(Model.OwnerEmail))
                    {
                        <a asp-page="/Messages/Conversation"
                           asp-route-to="@(Model.Listing?.UserId ?? 0)"
                           asp-route-listing="@(Model.Listing?.Id ?? 0)"
                           style="flex:1;padding:10px 12px;background:linear-gradient(90deg,#6c5ce7,#7F77DD);color:#fff;border-radius:10px;text-decoration:none;font-weight:800;text-align:center">
                            Üzenet küldése
                        </a>
                    }

                    @* Show return link to admin when ReturnUrl is present; otherwise fallback to local Index *@
                    @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
                    {
                        <a href="@Model.ReturnUrl" style="flex:1;padding:10px 12px;background:#eef2ff;color:#4c51bf;border-radius:10px;text-decoration:none;font-weight:700;text-align:center">Vissza az admin oldalra</a>
                    }
                    else
                    {
                        <a asp-page="./Index" style="flex:1;padding:10px 12px;background:#eef2ff;color:#4c51bf;border-radius:10px;text-decoration:none;font-weight:700;text-align:center">Vissza</a>
                    }
                </div>
            </div>

            <!-- ✅ VISSZARAKOTT: Biztonság és jelentés + Jelentés gomb -->
            <div style="background:#fff;padding:14px;border-radius:12px;box-shadow:0 6px 20px rgba(2,6,23,0.04)">
                <div style="font-weight:800;color:#111;margin-bottom:8px">Biztonság és jelentés</div>
                <div style="color:#6b7280;font-size:14px;margin-bottom:10px">Találtál valami gyanúsat? Jelentheted ezt a hirdetést.</div>
                <div style="display:flex;gap:8px">
                    <a asp-page="/Reports/Create"
                       asp-route-listingId="@l.Id"
                       style="flex:1;padding:8px 10px;background:#fff7ed;color:#c2410c;border-radius:8px;text-decoration:none;font-weight:700;text-align:center">
                        Jelentés
                    </a>

                    @if (Model.CanEdit)
                    {
                        <a asp-page="./Edit"
                           asp-route-azon="@l.Id"
                           style="flex:1;padding:8px 10px;background:#eef2ff;color:#4c51bf;border-radius:8px;text-decoration:none;font-weight:700;text-align:center">
                            Szerkesztés
                        </a>
                    }

                    @if (Model.CanDelete)
                    {
                        <form method="post" asp-page-handler="Delete" style="flex:1;margin:0" onsubmit="return confirm('Biztosan törölni szeretnéd ezt a hirdetést?');">
                            <input type="hidden" name="azon" value="@l.Id" />
                            <button type="submit" class="btn" style="width:100%;padding:8px 10px;background:#fff1f2;color:#ef4444;border-radius:8px;font-weight:700">Törlés</button>
                        </form>
                    }
                </div>
            </div>
        </aside>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            (function () {
                var carouselEl = document.getElementById('listingCarousel');
                if (!carouselEl) return;

                // Modal (use the proven old behavior: show modal + move to correct index)
                var modalEl = document.getElementById('listingModal');
                var modalCarouselEl = document.getElementById('listingModalCarousel');
                if (!modalEl || !modalCarouselEl) return;

                var modal = new bootstrap.Modal(modalEl, { backdrop: false, keyboard: true });

                function modalCarouselInstance() {
                    return bootstrap.Carousel.getOrCreateInstance(modalCarouselEl, { touch: true, wrap: true, interval: false });
                }

                function resetZoom() {
                    modalEl.querySelectorAll('.zoom-stage.zoomed-in').forEach(function (s) {
                        s.classList.remove('zoomed-in');
                    });
                }

                document.querySelectorAll('#listingCarousel .carousel-item img').forEach(function (img) {
                    img.addEventListener('click', function () {
                        var idx = parseInt(this.getAttribute('data-index') || '0', 10);
                        resetZoom();
                        modal.show();
                        setTimeout(function () { modalCarouselInstance().to(idx); }, 120);
                    });
                });

                document.querySelectorAll('#listingCarousel [data-bs-slide-to]').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var idx = parseInt(this.getAttribute('data-bs-slide-to') || '0', 10);
                        resetZoom();
                        modal.show();
                        setTimeout(function () { modalCarouselInstance().to(idx); }, 120);
                    });
                });

                // keep sliding stable: always unzoom when slide starts
                modalCarouselEl.addEventListener('slide.bs.carousel', resetZoom);

                // click to toggle zoom (no animation)
                modalCarouselEl.addEventListener('click', function (e) {
                    var stage = e.target.closest('.zoom-stage');
                    if (!stage) return;
                    stage.classList.toggle('zoomed-in');
                });

                var modalCloseBtn = document.getElementById('listingModalClose');
                if (modalCloseBtn) modalCloseBtn.addEventListener('click', function () { modal.hide(); });

                modalEl.addEventListener('click', function (e) {
                    if (e.target === modalEl) modal.hide();
                });
            })();
        </script>
    }
}