@page "{azon:int}"
@model SwoopMarketplaceProjectFrontend.Pages.Listings.DetailsModel
@using System.Security.Cryptography
@using System.Text
@using SwoopMarketplaceProjectFrontend.Services

@functions {
    private static string GravatarUrl(string? email, int size = 128)
    {
        if (string.IsNullOrWhiteSpace(email))
            return "/images/avatar.png";
        using var md5 = MD5.Create();
        var hash = BitConverter.ToString(md5.ComputeHash(Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()))).Replace("-", "").ToLowerInvariant();
        return $"https://www.gravatar.com/avatar/{hash}?s={size}&d=identicon";
    }

    private static string FormatPrice(decimal price) => price.ToString("C");
}

@if (Model.Listing is null)
{
    <div style="max-width:1100px;margin:28px auto;padding:16px;background:#fff;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.06);">
        <h2 style="margin:0 0 8px;font-family:Segoe UI,Roboto,Arial,sans-serif;color:#222">Hirdetés nem található</h2>
        <p style="color:#6b7280">A kért hirdetés nem elérhető.</p>
        <a asp-page="./Index" style="display:inline-block;margin-top:10px;padding:8px 12px;background:#eef2ff;color:#4c51bf;border-radius:8px;text-decoration:none;font-weight:700">Vissza a listához</a>
    </div>
}
else
{

    @* Add a small bookmark toggle near the listing title or controls *@
    @if (Model.Listing != null)
    {
        <div style="display:flex;align-items:center;gap:8px;">
            <h1 style="margin:auto">@Model.Listing.Title</h1>

            <form method="post" asp-page-handler="ToggleBookmark" style="margin:0;">
                <input type="hidden" name="azon" value="@Model.Listing.Id" />
                <button type="submit" title="Toggle bookmark" style="background:none;border:none;padding:6px;cursor:pointer;">
                    @if (Model.IsBookmarked)
                    {
                        <!-- filled bookmark (bookmarked) -->
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M6 2a1 1 0 00-1 1v18l7-4 7 4V3a1 1 0 00-1-1H6z" />
                        </svg>
                    }
                    else
                    {
                        <!-- outline bookmark (not bookmarked) -->
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M6 2a1 1 0 00-1 1v18l7-4 7 4V3a1 1 0 00-1-1H6z" />
                        </svg>
                    }
                </button>
            </form>
        </div>
    }

    var l = Model.Listing;
    // Prefer stored profile image when available; fallback to gravatar
    var avatar = !string.IsNullOrWhiteSpace(Model.OwnerProfileImageUrl) ? Model.OwnerProfileImageUrl : GravatarUrl(Model.OwnerEmail);

    // safe fallback list - avoid nullable dereference by materializing a non-null local
    var imageList = l.ImageUrls ?? new List<string>();
    var images = imageList.Any() ? imageList : new List<string> { "/images/placeholder.png" };

    <div style="max-width:1100px;margin:18px auto;display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start;">
        <!-- Left / gallery (Bootstrap carousel with thumbnails) -->
        <section style="flex:1 1 640px;min-width:320px;">
            <div style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 10px 30px rgba(2,6,23,0.06);padding:0;">
                <div id="listingCarousel" class="carousel slide" data-bs-ride="false" data-bs-touch="true">
                    <div class="carousel-inner" style="height:460px;">
                        @for (int i = 0; i < images.Count; i++)
                        {
                            var url = images[i];
                            var active = i == 0 ? "active" : "";
                            <div class="carousel-item @active" style="height:100%;">
                                <img src="@url" class="d-block w-100" style="height:100%;object-fit:cover;display:block" alt="listing image @i" />
                            </div>
                        }
                    </div>

                    @if (images.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev" aria-label="Previous">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next" aria-label="Next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        </button>
                    }
                </div>

                @* thumbnails *@
                @if (images.Count > 1)
                {
                    <div class="d-flex gap-2 p-3" style="overflow-x:auto;background:#fff;border-top:1px solid #f1f5f9;">
                        @for (int i = 0; i < images.Count; i++)
                        {
                            var url = images[i];
                            <button type="button" class="btn p-0 border-0" data-bs-target="#listingCarousel" data-bs-slide-to="@i" style="flex:0 0 auto;">
                                <img src="@url" alt="thumb @i" style="width:88px;height:64px;object-fit:cover;border-radius:8px;border:1px solid #e6eef8" />
                            </button>
                        }
                    </div>
                }

                <div style="padding:16px;">
                    <h1 style="margin:0 0 8px;font-size:22px;font-weight:800;color:#111">@l.Title</h1>
                    <div style="color:#6b7280;font-size:13px;margin-bottom:12px">@((l.Location ?? "Ismeretlen hely")) • @l.CreatedAt.ToString("yyyy-MM-dd")</div>

                    <div style="color:#333;line-height:1.5;font-size:15px;padding:12px;background:linear-gradient(180deg,#fff,#fbfdff);border-radius:8px;border:1px solid #f1f5f9;">
                        @l.Description
                    </div>

                    <div style="display:flex;gap:10px;margin-top:14px;flex-wrap:wrap">
                        <span style="padding:8px 10px;border-radius:10px;background:#f7f9fc;color:#374151;font-weight:700">Állapot: @ConditionMapper.FriendlyName(l.Condition)</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Right / seller & actions -->
        <aside style="width:360px;min-width:280px;display:flex;flex-direction:column;gap:12px">
            <div style="background:#fff;padding:16px;border-radius:12px;box-shadow:0 10px 30px rgba(2,6,23,0.06)">
                <div style="display:flex;gap:12px;align-items:center">
                    <div style="width:72px;height:72px;border-radius:999px;overflow:hidden;box-shadow:0 8px 20px rgba(12,18,44,0.06)">
                        <img src="@avatar" alt="seller" style="width:100%;height:100%;object-fit:cover;display:block" />
                    </div>
                    <div style="flex:1">
                        <div style="font-weight:800;font-size:16px;color:#111">@((Model.OwnerEmail?.Split('@').FirstOrDefault()) ?? "Eladó")</div>
                        <div style="font-size:13px;color:#6b7280">@Model.OwnerEmail</div>
                    </div>
                </div>

                <div style="margin-top:14px;display:flex;gap:10px;flex-wrap:wrap">
                    @if (!string.IsNullOrWhiteSpace(Model.OwnerEmail))
                    {
                        <a href="mailto:@Model.OwnerEmail" style="flex:1;padding:10px 12px;background:linear-gradient(90deg,#00b894,#00d084);color:#fff;border-radius:10px;text-decoration:none;font-weight:800;text-align:center">Üzenet küldése</a>
                    }
                    <a asp-page="./Index" style="flex:1;padding:10px 12px;background:#eef2ff;color:#4c51bf;border-radius:10px;text-decoration:none;font-weight:700;text-align:center">Vissza</a>
                </div>
            </div>

            <div style="background:#fff;padding:14px;border-radius:12px;box-shadow:0 6px 20px rgba(2,6,23,0.04)">
                <div style="font-weight:800;color:#111;margin-bottom:8px">Biztonság és jelentés</div>
                <div style="color:#6b7280;font-size:14px;margin-bottom:10px">Találtál valami gyanúsat? Jelentheted ezt a hirdetést.</div>
                <div style="display:flex;gap:8px">
                    <a asp-page="/Reports/Create" asp-route-listingId="@l.Id" style="flex:1;padding:8px 10px;background:#fff7ed;color:#c2410c;border-radius:8px;text-decoration:none;font-weight:700;text-align:center">Jelentés</a>

                    @* Edit only for owner *@
                    @if (Model.CanEdit)
                    {
                        <a asp-page="./Edit" asp-route-azon="@l.Id" style="flex:1;padding:8px 10px;background:#eef2ff;color:#4c51bf;border-radius:8px;text-decoration:none;font-weight:700;text-align:center">Szerkesztés</a>
                    }

                    @* Delete for owner or admin *@
                    @if (Model.CanDelete)
                    {
                        <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Are you sure you want to delete this listing?');" style="flex:1;margin:0">
                            <input type="hidden" name="azon" value="@l.Id" />
                            <button type="submit" class="btn" style="width:100%;padding:8px 10px;background:#fff1f2;color:#ef4444;border-radius:8px;font-weight:700">Törlés</button>
                        </form>
                    }
                </div>
            </div>

            <div style="background:#fff;padding:14px;border-radius:12px;box-shadow:0 6px 20px rgba(2,6,23,0.04)">
                <div style="font-weight:800;color:#111;margin-bottom:8px">Kapcsolódó hirdetések</div>
                <div style="color:#6b7280;font-size:14px">Hamarosan: további ajánlatok ugyanattól az eladótól vagy kategóriából.</div>
            </div>
        </aside>
    </div>

    

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script>
            (function () {
                var carouselEl = document.getElementById('listingCarousel');
                if (!carouselEl) return;
                carouselEl.addEventListener('keydown', function (e) {
                    if (e.key === 'ArrowLeft') bootstrap.Carousel.getInstance(carouselEl).prev();
                    if (e.key === 'ArrowRight') bootstrap.Carousel.getInstance(carouselEl).next();
                });
            })();
        </script>
    }
}