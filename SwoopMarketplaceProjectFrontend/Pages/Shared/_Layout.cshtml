@using SwoopMarketplaceProjectFrontend.Services
@using System.Security.Cryptography
@using System.Text
@inject AuthSession AuthSession
@inject UserApi UserApi
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Swoop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SwoopMarketplaceProjectFrontend.styles.css" asp-append-version="true" />
    <style>
        body {
            font-family: 'Segoe UI', Roboto, Arial, sans-serif;
            background: #f5f5f8;
            color: #1a1a2e;
        }

        /* ── Navbar ── */
        .swoop-nav {
            background: #fff;
            border-bottom: 1px solid #ebebf0;
            padding: 0 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 1px 8px rgba(26,26,46,0.06);
        }

        .swoop-nav .container {
            display: flex;
            align-items: center;
            height: 60px;
            gap: 8px;
        }

        /* Logo */
        .swoop-logo {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .swoop-logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #1a2744;
            letter-spacing: -.5px;
        }

        /* Nav links */
        .swoop-nav-links {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-left: 24px;
            flex-grow: 1;
        }

        .swoop-nav-link {
            font-size: 14px;
            font-weight: 600;
            color: #555;
            text-decoration: none;
            padding: 6px 12px;
            border-radius: 8px;
            transition: background .15s, color .15s;
        }

        .swoop-nav-link:hover {
            background: #f0effe;
            color: #6c5ce7;
        }

        /* Right-side nav */
        .swoop-nav-right {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
        }

        .swoop-username {
            font-size: 14px;
            font-weight: 600;
            color: #1a1a2e;
        }

        .swoop-badge {
            font-size: 11px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 999px;
        }

        .swoop-badge-admin {
            background: #fee2e2;
            color: #b91c1c;
        }

        .swoop-badge-user {
            background: #fef9c3;
            color: #92400e;
        }

        .swoop-btn-logout {
            font-size: 13px;
            font-weight: 600;
            color: #888;
            background: none;
            border: none;
            cursor: pointer;
            padding: 6px 10px;
            border-radius: 8px;
            font-family: 'Segoe UI', Roboto, Arial, sans-serif;
            transition: background .15s, color .15s;
        }

        .swoop-btn-logout:hover {
            background: #fef2f2;
            color: #b91c1c;
        }

        .swoop-btn-login {
            font-size: 13px;
            font-weight: 600;
            color: #6c5ce7;
            text-decoration: none;
            padding: 6px 14px;
            border: 1px solid #d4d0f8;
            border-radius: 8px;
            transition: background .15s;
        }

        .swoop-btn-login:hover {
            background: #f0effe;
        }

        .swoop-btn-register {
            font-size: 13px;
            font-weight: 700;
            color: #fff;
            text-decoration: none;
            padding: 7px 16px;
            background: #6c5ce7;
            border-radius: 8px;
            transition: background .15s;
        }

        .swoop-btn-register:hover {
            background: #534AB7;
            color: #fff;
        }

        /* Avatar */
        .swoop-nav-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            overflow: hidden;
            border: 2px solid #e0deff;
            display: inline-flex;
            flex-shrink: 0;
        }

        .swoop-nav-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* ── Main content ── */
        .swoop-main {
            /* use flex-grow instead of hard calc; body is a column flex container */
            flex: 1 1 auto;
            min-height: 0; /* allow flex children to shrink correctly */
            padding: 2rem 0 3rem;
        }

        /* ── Footer ── */
        .swoop-footer {
            background: #fff;
            border-top: 1px solid #ebebf0;
            padding: 16px 0;
            font-size: 13px;
            color: #aaa;
        }

        .swoop-footer a {
            color: #6c5ce7;
            text-decoration: none;
        }

        .swoop-footer a:hover {
            text-decoration: underline;
        }

        /* ── Floating CTA ── */
        .fab {
            position: fixed;
            right: 24px;
            bottom: 28px;
            background: #6c5ce7;
            color: #fff;
            padding: 13px 20px;
            border-radius: 999px;
            box-shadow: 0 8px 28px rgba(108,92,231,0.30);
            font-weight: 800;
            text-decoration: none;
            z-index: 1200;
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: 'Segoe UI', Roboto, Arial, sans-serif;
            transition: background .15s, box-shadow .15s;
        }

        .fab:hover {
            background: #534AB7;
            color: #fff;
            box-shadow: 0 12px 32px rgba(108,92,231,0.38);
        }

        .fab small {
            font-weight: 500;
            font-size: 11px;
            opacity: 0.88;
            display: block;
            line-height: 1;
        }

        .fab-label {
            line-height: 1.2;
        }
    </style>
</head>
<body>
    <header>
        <nav class="swoop-nav">
            <div class="container">

                @* Logo *@
                <a class="swoop-logo" asp-area="" asp-page="/Index">
                    <img src="https://localhost:7000/images/swooplogo.png" alt="Swoop" height="52" style="max-width:180px; object-fit:contain;" />
                </a>

                @* Left nav links *@
                @if (AuthSession.IsSignedIn)
                {
                    <div class="swoop-nav-links">
                        <a class="swoop-nav-link" asp-area="" asp-page="/Listings/Index">Hirdetések</a>
                        <a class="swoop-nav-link" asp-area="" asp-page="/Listings/Saved">Mentett</a>
                    </div>
                }

                @* Right side *@
                <div class="swoop-nav-right">
                    @if (!AuthSession.IsSignedIn)
                    {
                        <a class="swoop-btn-login" asp-page="/Account/Login">Bejelentkezés</a>
                        <a class="swoop-btn-register" asp-page="/Account/Register">Regisztráció</a>
                    }
                    else
                    {
                        string displayName = AuthSession.GetEmail() ?? "";
                        try
                        {
                            var userId = AuthSession.GetUserId();
                            if (userId.HasValue)
                            {
                                var u = await UserApi.GetByAzonAsync(userId.Value);
                                if (u != null && !string.IsNullOrWhiteSpace(u.Username))
                                    displayName = u.Username;
                            }
                            else
                            {
                                var email = AuthSession.GetEmail();
                                if (!string.IsNullOrWhiteSpace(email))
                                {
                                    var u = await UserApi.GetByEmailAsync(email);
                                    if (u != null && !string.IsNullOrWhiteSpace(u.Username))
                                        displayName = u.Username;
                                }
                            }
                        }
                        catch { }

                        <span class="swoop-username">
                            @displayName
                            @if (AuthSession.IsInRole("Admin"))
                            {
                                <span class="swoop-badge swoop-badge-admin">Admin</span>
                            }
                            else if (AuthSession.IsInRole("User"))
                            {
                                <span class="swoop-badge swoop-badge-user">Felhasználó</span>
                            }
                        </span>

                        @* Admin gomb: csak Admin vagy Owner/Tulaj szerepű felhasználók látják *@
                        @if (AuthSession.IsInRole("Admin") || AuthSession.IsInRole("Owner") || AuthSession.IsInRole("Tulaj"))
                        {
                            <a class="swoop-nav-link" asp-area="" asp-page="/Admin/Index">Admin</a>
                        }

                        <form method="post" asp-page="/Account/Logout" class="d-inline">
                            <button type="submit" class="swoop-btn-logout">Kijelentkezés</button>
                        </form>

                       
                            var avatarUrl = "/images/avatar.png";
                            var avatarEmail = AuthSession.GetEmail();
                            if (!string.IsNullOrWhiteSpace(avatarEmail))
                            {
                                try
                                {
                                    var user = await UserApi.GetByEmailAsync(avatarEmail);
                                    if (user != null && !string.IsNullOrWhiteSpace(user.ProfileImageUrl))
                                    {
                                        avatarUrl = user.ProfileImageUrl;
                                    }
                                    else
                                    {
                                        using var md5 = MD5.Create();
                                        var hash = BitConverter.ToString(md5.ComputeHash(Encoding.UTF8.GetBytes(avatarEmail.Trim().ToLowerInvariant()))).Replace("-", "").ToLowerInvariant();
                                        avatarUrl = $"https://www.gravatar.com/avatar/{hash}?s=128&d=identicon";
                                    }
                                }
                                catch
                                {
                                    using var md5 = MD5.Create();
                                    var hash = BitConverter.ToString(md5.ComputeHash(Encoding.UTF8.GetBytes(avatarEmail.Trim().ToLowerInvariant()))).Replace("-", "").ToLowerInvariant();
                                    avatarUrl = $"https://www.gravatar.com/avatar/{hash}?s=128&d=identicon";
                                }
                            }
                        
                        <a asp-area="" asp-page="/Users/MyProfile" title="Profilom">
                            <span class="swoop-nav-avatar"><img src="@avatarUrl" alt="profil" /></span>
                        </a>
                    }
                </div>

            </div>
        </nav>
    </header>

    <div class="container swoop-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="swoop-footer">
        <div class="container d-flex justify-content-between align-items-center">
            <span>&copy; 2026 Swoop Marketplace</span>
            <a asp-area="" asp-page="/Privacy">Adatvédelem</a>
        </div>
    </footer>

    @if (AuthSession.IsSignedIn)
    {
        <a class="fab" asp-page="/Listings/Create" title="Hirdetés feladása">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 5v14M5 12h14" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="fab-label">
                <div style="font-size:14px;font-weight:800;line-height:1.2">Hirdetés feladása</div>
                <small>Gyors és egyszerű</small>
            </div>
        </a>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
