@using SwoopMarketplaceProjectFrontend.Services
@using System.Security.Cryptography
@using System.Text
@inject AuthSession AuthSession
@inject UserApi UserApi
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SwoopMarketplaceProjectFrontend</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SwoopMarketplaceProjectFrontend.styles.css" asp-append-version="true" />
    <style>
        /* Floating CTA */
        .fab {
            position: fixed;
            right: 20px;
            bottom: 24px;
            background: linear-gradient(90deg,#6c5ce7,#5a4de6);
            color: #fff;
            padding: 14px 18px;
            border-radius: 999px;
            box-shadow: 0 14px 36px rgba(92,71,229,0.20);
            font-weight: 800;
            text-decoration: none;
            z-index: 1200;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .fab small {
                font-weight: 600;
                font-size: 12px;
                opacity: 0.95;
            }

        /* profile avatar in navbar */
        .nav-avatar {
            width: 36px;
            height: 36px;
            border-radius: 999px;
            overflow: hidden;
            display: inline-block;
            vertical-align: middle;
        }

            .nav-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Swoop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (AuthSession.IsSignedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Listings/Index">Hírdetések</a>
                            </li>
                        }

                        @* Replace "My profile" text link with user's avatar when signed in *@

                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (!AuthSession.IsSignedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Login">Bejelentkezés</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Register">Regisztráció</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <span class="nav-link text-success">
                                    @AuthSession.GetEmail()
                                    @if (AuthSession.IsInRole("Admin"))
                                    {
                                        <span class="badge bg-danger ms-2">Admin</span>
                                    }
                                    else if (AuthSession.IsInRole("User"))
                                    {
                                        <span class="badge bg-warning ms-2">Felhasználó</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout" class="d-inline">
                                    <button type="submit" class="btn btn-link nav-link text-danger">Kijelentkezés</button>
                                </form>
                            </li>
                        }
                        <!-- Header CTA -->
                        @if (AuthSession.IsSignedIn)
                        {
                            var avatarUrl = "/images/avatar.png";
                            var email = AuthSession.GetEmail();
                            if (!string.IsNullOrWhiteSpace(email))
                            {
                                try
                                {
                                    // Use the ProfileImageUrl returned by UserApi directly.
                                    // UserApi.GetByEmailAsync already normalizes to absolute URL when possible.
                                    var user = await UserApi.GetByEmailAsync(email);
                                    if (user != null && !string.IsNullOrWhiteSpace(user.ProfileImageUrl))
                                    {
                                        avatarUrl = user.ProfileImageUrl;
                                    }
                                    else
                                    {
                                        using var md5 = MD5.Create();
                                        var hash = BitConverter.ToString(md5.ComputeHash(Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()))).Replace("-", "").ToLowerInvariant();
                                        avatarUrl = $"https://www.gravatar.com/avatar/{hash}?s=128&d=identicon";
                                    }
                                }
                                catch
                                {
                                    using var md5 = MD5.Create();
                                    var hash = BitConverter.ToString(md5.ComputeHash(Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()))).Replace("-", "").ToLowerInvariant();
                                    avatarUrl = $"https://www.gravatar.com/avatar/{hash}?s=128&d=identicon";
                                }
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Users/MyProfile" title="My profile" style="display:flex;align-items:center;gap:8px">
                                    <span class="nav-avatar"><img src="@avatarUrl" alt="profile" /></span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - SwoopMarketplace - <a asp-area="" asp-page="/Privacy">Adatvédelem</a>
        </div>
    </footer>
    @if (AuthSession.IsSignedIn)
    {
        <!-- Floating CTA -->
        <a class="fab" asp-page="/Listings/Create" title="Hirdetés feladása">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
            <div>
                <div style="line-height:1">Hirdetés feladása</div>
                <small>Add new listing</small>
            </div>
        </a>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>