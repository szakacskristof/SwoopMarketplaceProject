@page
@model SwoopMarketplaceProjectFrontend.Pages.Admin.IndexModel
@using SwoopMarketplaceProjectFrontend.Dtos
@inject SwoopMarketplaceProjectFrontend.Services.AuthSession AuthSession
@{
    ViewData["Title"] = "Admin Oldal";
}

<h1>Admin felület</h1>

<ul class="nav nav-tabs" id="adminTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.SelectedTab == "listings" ? "active" : "")" data-bs-toggle="tab" data-bs-target="#tab-listings" type="button">Hirdetések</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.SelectedTab == "users" ? "active" : "")" data-bs-toggle="tab" data-bs-target="#tab-users" type="button">Felhasználók</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.SelectedTab == "reports" ? "active" : "")" data-bs-toggle="tab" data-bs-target="#tab-reports" type="button">Reportolt hirdetések</button>
    </li>
</ul>

<div class="tab-content mt-3">
    <div class="tab-pane fade @(Model.SelectedTab == "listings" ? "show active" : "")" id="tab-listings" role="tabpanel">
        <h4>Összes hirdetés</h4>
        @if (Model.Listings?.Any() != true)
        {
            <p>Nincs hirdetés.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Cím</th>
                        <th>Tulaj</th>
                        <th>Ár</th>
                        <th style="width:260px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Listings)
                    {
                        <tr>
                            <td>@item.Listing.Title</td>
                            <td>@item.OwnerEmail</td>
                            <td>@item.Listing.Price.ToHuf()</td>
                            <td>
                                <button class="btn btn-sm btn-info me-1" type="button" data-bs-toggle="modal" data-bs-target="#modal-listing-@item.Listing.Id">
                                    Megtekintés
                                </button>

                                <a asp-page="/Listings/Edit" asp-route-azon="@item.Listing.Id" class="btn btn-sm btn-warning me-1">Szerkesztés</a>

                                <form method="post" asp-page-handler="DeleteListing" class="d-inline" onsubmit="return confirm('Törölni szeretnéd a hirdetést?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="azon" value="@item.Listing.Id" />
                                    <button class="btn btn-sm btn-danger" type="submit">Törlés</button>
                                </form>
                            </td>
                        </tr>

                        <div class="modal fade" id="modal-listing-@item.Listing.Id" tabindex="-1" aria-labelledby="modalLabel-@item.Listing.Id" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="modalLabel-@item.Listing.Id">@item.Listing.Title</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="row">
                                            <div class="col-md-5 mb-3">
                                                <img src="@(item.Listing.ImageUrls.FirstOrDefault() ?? "/images/placeholder.png")" alt="Kép" class="img-fluid rounded" style="width:100%;height:auto;object-fit:cover;" />
                                            </div>
                                            <div class="col-md-7">
                                                <p><strong>Ár:</strong> @item.Listing.Price.ToHuf()</p>
                                                <p><strong>Tulaj:</strong> @item.OwnerEmail</p>
                                                <p><strong>Kategória:</strong> @(item.Listing.CategoryName ?? "-")</p>
                                                <p><strong>Állapot:</strong> @item.Listing.Condition</p>
                                                <p><strong>Hely:</strong> @(item.Listing.Location ?? "-")</p>
                                                <p><strong>Státusz:</strong> @(item.Listing.Status ?? "-")</p>
                                                <p><strong>Létrehozva:</strong> @item.Listing.CreatedAt.ToString("yyyy-MM-dd")</p>
                                                <hr />
                                                <p><strong>Leírás:</strong></p>
                                                <div style="white-space:pre-wrap;">@item.Listing.Description</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <a asp-page="/Listings/Edit" asp-route-azon="@item.Listing.Id" class="btn btn-warning">Szerkesztés</a>

                                        <form method="post" asp-page-handler="DeleteListing" class="d-inline" onsubmit="return confirm('Biztosan törlöd ezt a hirdetést?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="azon" value="@item.Listing.Id" />
                                            <button class="btn btn-danger" type="submit">Törlés</button>
                                        </form>

                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bezár</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="tab-pane fade @(Model.SelectedTab == "users" ? "show active" : "")" id="tab-users" role="tabpanel">
        <h4>Felhasználók</h4>
        @if (Model.Users?.Any() != true)
        {
            <p>Nincs felhasználó.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Felhasználónév</th>
                        <th>Email</th>
                        <th>Szerep</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>@u.Username</td>
                            <td>@u.Email</td>
                            <td>@(u.Roles?.Any() == true ? string.Join(", ", u.Roles) : "User")</td>
                            <td>
                                <form method="post" asp-page-handler="DeleteUser" class="d-inline">
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <button class="btn btn-sm btn-danger" type="submit" onclick="return confirm('Törölni szeretnéd a felhasználót?');">Töröl</button>
                                </form>

                                @if (AuthSession.IsInRole("Owner") || AuthSession.IsInRole("Tulaj"))
                                {
                                    var current = (u.Roles?.FirstOrDefault() ?? "User");
                                    if (!string.Equals(current, "User", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form method="post" asp-page-handler="SetUserRole" class="d-inline ms-1">
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <input type="hidden" name="role" value="User" />
                                            <button class="btn btn-sm btn-secondary" type="submit" onclick="return confirm('Felhasználóként szeretnéd beállítani?');">Beállít felhasználónak</button>
                                        </form>
                                    }
                                    if (!string.Equals(current, "Admin", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form method="post" asp-page-handler="SetUserRole" class="d-inline ms-1">
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <input type="hidden" name="role" value="Admin" />
                                            <button class="btn btn-sm btn-warning" type="submit" onclick="return confirm('Admin szerepet szeretnél adni ennek a felhasználónak?');">Beállít adminnak</button>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="tab-pane fade @(Model.SelectedTab == "reports" ? "show active" : "")" id="tab-reports" role="tabpanel">
        <h4>Reportok</h4>
        @if (Model.Reports?.Any() != true)
        {
            <p>Nincs report.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Leírás</th>
                        <th>Jelentette</th>
                        <th>Dátum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Reports)
                    {
                        <tr>
                            <td style="max-width:45ch;white-space:normal;overflow-wrap:break-word;">@r.Description</td>
                            <td>@(string.IsNullOrWhiteSpace(r.ReporterUsername) ? (r.ReporterEmail ?? "-") : r.ReporterUsername)</td>
                            <td>@(r.ReportedAt?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>
                                <a asp-page="/Listings/Details"
                                   asp-route-azon="@r.ListingId"
                                   asp-route-returnUrl="@(Url.Page("/Admin/Index", new { SelectedTab = "reports" }))"
                                   class="btn btn-sm btn-info me-1">
                                    Megnyit
                                </a>

                                <form method="post" asp-page-handler="DeleteReport" class="d-inline">
                                    <input type="hidden" name="id" value="@r.ReportId" />
                                    <button class="btn btn-sm btn-danger" type="submit" onclick="return confirm('Törölni szeretnéd a reportot?');">Report Törlése</button>
                                </form>

                                @* NEW: Delete both the reported listing and the report *@
                                <form method="post" asp-page-handler="DeleteListingAndReport" class="d-inline ms-1" onsubmit="return confirm('Törölni szeretnéd a hirdetést és a hozzá tartozó reportot?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="listingId" value="@r.ListingId" />
                                    <input type="hidden" name="reportId" value="@r.ReportId" />
                                    <button class="btn btn-sm btn-danger" type="submit">Hírdetés és report törlése</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var selected = '@Model.SelectedTab';
            if (selected) {
                var tabId = selected === 'users' ? '#tab-users' : (selected === 'reports' ? '#tab-reports' : '#tab-listings');
                var tab = document.querySelector('button[data-bs-target="' + tabId + '"]');
                if (tab) {
                    var tabTrigger = new bootstrap.Tab(tab);
                    tabTrigger.show();
                }
            }
        })();
    </script>
}